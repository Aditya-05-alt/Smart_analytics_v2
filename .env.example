# ---------------------------------------------------------------------------
# Environment variables for Wheeler SmartAnalytics V2
# ---------------------------------------------------------------------------
#
# DO NOT put real secrets in this file — it is committed to git as a template.
#
# For local development:
#   1. Copy this file to `.env.local` in the SAME folder as `package.json`
#      (project root: c:\htmls\Smart_analytics_v2).
#   2. Replace the placeholder values with your real Supabase keys.
#   3. Restart `npm run dev` after changing env vars.
#
# Next.js loads, in order: `.env` → `.env.local` → `.env.development` (etc.).
# `.env.local` overrides `.env` and is listed in `.gitignore` by default.
#
# ---------------------------------------------------------------------------

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional — local dev only. When set, together with `NODE_ENV=development` and the
# temp dev cookie from POST /api/dev-session, dashboard reads use the service role
# so RLS does not block `smart_ga4_config` / `smart_master_db` while testing.
# Never commit the real key; never enable this pattern in production builds.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
