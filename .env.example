# Copy to .env.local for local dev. On Vercel: Project -> Settings -> Environment Variables.

# Required - Supabase project (Dashboard -> Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional - local dev only (temp demo login + dashboard reads without Supabase auth)
# Never set on Vercel production.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
